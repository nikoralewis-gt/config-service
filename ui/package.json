{
  "name": "config-service-ui",
  "version": "1.0.0",
  "description": "Admin web interface for Config Service API",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "type-check": "tsc --noEmit",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:all": "pnpm test:run && pnpm test:e2e"
  },
  "keywords": ["config-service", "admin", "web-components"],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@config-hub/client": "file:../config-service-client"
  },
  "devDependencies": {
    "@playwright/test": "^1.50.0",
    "@testing-library/dom": "^10.0.0",
    "@types/node": "^24.0.0",
    "@vitest/coverage-v8": "^3.0.0",
    "@vitest/ui": "^3.0.0",
    "jsdom": "^26.0.0",
    "msw": "^2.0.0",
    "typescript": "^5.9.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0"
  }
}
